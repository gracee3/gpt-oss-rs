# gpt-oss-rs Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
GPT_OSS_RS_HOST=0.0.0.0
GPT_OSS_RS_PORT=8000
RUST_LOG=info

# --- Model ---
# HuggingFace model name or local path
# GPT_OSS_RS_MODEL=Qwen/Qwen2.5-1.5B
# GPT_OSS_RS_MAX_MODEL_LEN=2048
# GPT_OSS_RS_DTYPE=auto

# --- GPU ---
# CUDA_VISIBLE_DEVICES=0
# GPT_OSS_RS_GPU_MEMORY_UTILIZATION=0.90
# GPT_OSS_RS_TENSOR_PARALLEL_SIZE=1

# --- Kernel directory (compiled PTX files) ---
# GPT_OSS_RS_KERNEL_DIR=./kernels

# --- HuggingFace ---
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# HF_HOME=~/.cache/huggingface

# --- vast.ai deployment ---
# VASTAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Telemetry ---
# GPT_OSS_RS_DISABLE_TELEMETRY=false
# GPT_OSS_RS_PROMETHEUS_PORT=9090
