// Fused RMSNorm + GEMV using CuTE (CUTLASS 3.x)
//
// output[j] = dot(rmsnorm(hidden, norm_weight, eps), proj_weight[j, :])
//
// CuTE provides:
//   - Layout abstractions for bank-conflict-free shared memory
//   - Vectorized copy operations (auto-selects optimal width)
//   - Tensor views for type-safe indexing
//
// Grid: ({{OUT_DIM}}, 1, 1)  Block: ({{THREADS}}, 1, 1)
// Shared: {{HIDDEN_SIZE}} * sizeof(float) + NUM_WARPS * sizeof(float)

#include <cute/tensor.hpp>
#include <cute/algorithm/copy.hpp>
#include <cuda_fp16.h>

using namespace cute;

constexpr int HIDDEN = {{HIDDEN_SIZE}};
constexpr int OUTDIM = {{OUT_DIM}};
constexpr int NTHREADS = {{THREADS}};
constexpr int NWARPS = NTHREADS / 32;
constexpr float RMS_EPS = {{EPS}};

extern "C"
__global__ void __launch_bounds__(NTHREADS)
{{KERNEL_NAME}}(
    __half* __restrict__ output,
    const __half* __restrict__ hidden,
    const __half* __restrict__ norm_weight,
    const __half* __restrict__ proj_weight,
    float eps,
    int hidden_size,
    int out_dim
) {
    const int row = blockIdx.x;
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    // Shared memory: normalized hidden vector + warp reduction scratch
    extern __shared__ float smem[];
    float* s_hidden = smem;
    float* s_warp = smem + HIDDEN;

    // -- Phase 1: Load hidden into shared memory as f32, compute sum of squares --
    // CuTE tensor view over global f16 hidden vector
    auto g_hidden = make_tensor(make_gmem_ptr(hidden), make_layout(Int<HIDDEN>{}));
    // CuTE tensor view over shared f32 buffer
    auto s_buf = make_tensor(make_smem_ptr(s_hidden), make_layout(Int<HIDDEN>{}));

    float thread_sq = 0.0f;
    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        float v = __half2float(g_hidden(i));
        s_buf(i) = v;
        thread_sq += v * v;
    }

    // Warp-level reduction of sum-of-squares
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1)
        thread_sq += __shfl_xor_sync(0xffffffff, thread_sq, offset);

    if (lane_id == 0) s_warp[warp_id] = thread_sq;
    __syncthreads();

    // Final reduction across warps (thread 0)
    float sum_sq;
    if (tid == 0) {
        sum_sq = 0.0f;
        for (int w = 0; w < NWARPS; w++) sum_sq += s_warp[w];
        s_warp[0] = sum_sq;
    }
    __syncthreads();
    sum_sq = s_warp[0];

    // -- Phase 2: Normalize in shared memory --
    float rms_scale = rsqrtf(sum_sq / float(HIDDEN) + RMS_EPS);

    // CuTE tensor view over norm weights
    auto g_norm = make_tensor(make_gmem_ptr(norm_weight), make_layout(Int<HIDDEN>{}));

    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        s_buf(i) = s_buf(i) * rms_scale * __half2float(g_norm(i));
    }
    __syncthreads();

    // -- Phase 3: Dot product with proj_weight[row, :] using half2 vectorized loads --
    // CuTE tensor view over weight row (f16, read as half2 for 2x bandwidth)
    const __half* weight_row = proj_weight + row * HIDDEN;

    float dot = 0.0f;
    // Vectorized: process 2 elements at a time via half2
    constexpr int HIDDEN_H2 = HIDDEN / 2;
    const __half2* weight_row_h2 = reinterpret_cast<const __half2*>(weight_row);

    for (int i = tid; i < HIDDEN_H2; i += NTHREADS) {
        __half2 w2 = weight_row_h2[i];
        float w0 = __half2float(w2.x);
        float w1 = __half2float(w2.y);
        dot += s_buf(2 * i) * w0 + s_buf(2 * i + 1) * w1;
    }
    // Handle odd element
    if (HIDDEN % 2 != 0 && tid == 0) {
        int last = HIDDEN - 1;
        dot += s_buf(last) * __half2float(weight_row[last]);
    }

    // Warp reduction
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1)
        dot += __shfl_xor_sync(0xffffffff, dot, offset);

    // Cross-warp reduction
    if (lane_id == 0) s_warp[warp_id] = dot;
    __syncthreads();

    if (tid == 0) {
        float total = 0.0f;
        for (int w = 0; w < NWARPS; w++) total += s_warp[w];
        output[row] = __float2half(total);
    }
}
