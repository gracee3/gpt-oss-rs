// Fused SiLU*Mul + Down GEMV using CuTE (CUTLASS 3.x)
//
// output[j] = dot(silu(gate) * up, down_weight[j, :])
//
// Each block computes one output element. Threads stride over intermediate_size
// computing silu(gate[i]) * up[i] * weight[j, i] on the fly.
// No intermediate buffer needed -- activation is consumed as it's computed.
//
// Grid: ({{HIDDEN_SIZE}}, 1, 1)  Block: ({{THREADS}}, 1, 1)
// Shared: NUM_WARPS * sizeof(float) only (for warp reduction)

#include <cute/tensor.hpp>
#include <cuda_fp16.h>

using namespace cute;

constexpr int HIDDEN = {{HIDDEN_SIZE}};
constexpr int INTERMEDIATE = {{INTERMEDIATE_SIZE}};
constexpr int NTHREADS = {{THREADS}};
constexpr int NWARPS = NTHREADS / 32;

__device__ __forceinline__ float silu_f32(float x) {
    return x / (1.0f + expf(-x));
}

extern "C"
__global__ void __launch_bounds__(NTHREADS)
{{KERNEL_NAME}}(
    __half* __restrict__ output,
    const __half* __restrict__ gate,
    const __half* __restrict__ up,
    const __half* __restrict__ down_weight,
    int hidden_size,
    int intermediate_size
) {
    const int row = blockIdx.x;
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    extern __shared__ float smem[];
    float* s_warp = smem;

    // CuTE tensor views for gate and up (f16 global memory)
    auto g_gate = make_tensor(make_gmem_ptr(gate), make_layout(Int<INTERMEDIATE>{}));
    auto g_up = make_tensor(make_gmem_ptr(up), make_layout(Int<INTERMEDIATE>{}));

    // Weight row for this output element
    const __half* w_row = down_weight + row * INTERMEDIATE;

    // Compute fused dot product: sum_i silu(gate[i]) * up[i] * weight[row, i]
    float dot = 0.0f;

    // Vectorized: half2 loads for gate, up, and weight
    constexpr int INTER_H2 = INTERMEDIATE / 2;
    const __half2* gate_h2 = reinterpret_cast<const __half2*>(gate);
    const __half2* up_h2 = reinterpret_cast<const __half2*>(up);
    const __half2* w_h2 = reinterpret_cast<const __half2*>(w_row);

    for (int i = tid; i < INTER_H2; i += NTHREADS) {
        __half2 g2 = gate_h2[i];
        __half2 u2 = up_h2[i];
        __half2 w2 = w_h2[i];

        float g0 = __half2float(g2.x), g1 = __half2float(g2.y);
        float u0 = __half2float(u2.x), u1 = __half2float(u2.y);
        float w0 = __half2float(w2.x), w1 = __half2float(w2.y);

        dot += silu_f32(g0) * u0 * w0 + silu_f32(g1) * u1 * w1;
    }

    // Handle odd element
    if (INTERMEDIATE % 2 != 0 && tid == 0) {
        int last = INTERMEDIATE - 1;
        float g = __half2float(g_gate(last));
        float u = __half2float(g_up(last));
        float w = __half2float(w_row[last]);
        dot += silu_f32(g) * u * w;
    }

    // Warp reduction
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1)
        dot += __shfl_xor_sync(0xffffffff, dot, offset);

    // Cross-warp reduction
    if (lane_id == 0) s_warp[warp_id] = dot;
    __syncthreads();

    if (tid == 0) {
        float total = 0.0f;
        for (int w = 0; w < NWARPS; w++) total += s_warp[w];
        output[row] = __float2half(total);
    }
}
