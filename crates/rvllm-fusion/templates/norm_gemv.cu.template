// Fused RMSNorm + GEMV kernel
// output[j] = dot(rmsnorm(hidden, norm_weight, eps), proj_weight[j, :])
//
// Compile-time constants:
//   HIDDEN_SIZE = {{HIDDEN_SIZE}}
//   OUT_DIM     = {{OUT_DIM}}
//   THREADS     = {{THREADS}}
//   EPS         = {{EPS}}
//
// Grid:  (OUT_DIM, 1, 1)
// Block: (THREADS, 1, 1)

#include <cuda_fp16.h>

constexpr int HIDDEN  = {{HIDDEN_SIZE}};
constexpr int OUTDIM  = {{OUT_DIM}};
constexpr int NTHREADS = {{THREADS}};
constexpr float EPS   = {{EPS}}f;

// Elements per thread for the hidden dimension
constexpr int ELEMS_PER_THREAD = (HIDDEN + NTHREADS - 1) / NTHREADS;

extern "C"
__global__ void {{KERNEL_NAME}}(
    const half* __restrict__ hidden,       // [HIDDEN]
    const half* __restrict__ norm_weight,   // [HIDDEN]
    const half* __restrict__ proj_weight,   // [OUT_DIM, HIDDEN]
    half* __restrict__ output               // [OUT_DIM]
) {
    const int tid = threadIdx.x;

    // ------------------------------------------------------------------
    // Shared memory layout:
    //   normalized[HIDDEN] : f32 normalized hidden states
    //   reduce[NTHREADS]   : scratch for parallel reductions
    // ------------------------------------------------------------------
    __shared__ float normalized[HIDDEN];
    __shared__ float reduce[NTHREADS];

    // ==================================================================
    // Phase 1: RMSNorm
    //   - Load hidden (f16) into shared memory as f32
    //   - Parallel sum-of-squares reduction
    //   - Compute rms_scale = rsqrt(mean_sq + eps)
    //   - Multiply by norm_weight and store normalized result
    // ==================================================================

    // Each thread accumulates a partial sum of squares
    float partial_sq = 0.0f;

    #pragma unroll
    for (int i = 0; i < ELEMS_PER_THREAD; i++) {
        int idx = tid + i * NTHREADS;
        if (idx < HIDDEN) {
            float val = __half2float(hidden[idx]);
            normalized[idx] = val;
            partial_sq += val * val;
        }
    }

    // Store partial sum for reduction
    reduce[tid] = partial_sq;
    __syncthreads();

    // Tree reduction for sum of squares
    #pragma unroll
    for (int stride = NTHREADS / 2; stride > 0; stride >>= 1) {
        if (tid < stride) {
            reduce[tid] += reduce[tid + stride];
        }
        __syncthreads();
    }

    // Broadcast rms_scale to all threads
    float rms_scale = rsqrtf(reduce[0] / float(HIDDEN) + EPS);

    // Normalize: multiply by rms_scale and norm_weight, store back to shared
    #pragma unroll
    for (int i = 0; i < ELEMS_PER_THREAD; i++) {
        int idx = tid + i * NTHREADS;
        if (idx < HIDDEN) {
            normalized[idx] = normalized[idx] * rms_scale * __half2float(norm_weight[idx]);
        }
    }

    __syncthreads();

    // ==================================================================
    // Phase 2: GEMV (dot product)
    //   - Each block handles one output row j = blockIdx.x
    //   - All threads cooperate to dot normalized[HIDDEN] with proj_weight[j, :]
    //   - Use half2 vectorized loads for the weight matrix
    //   - Warp shuffle reduction to sum partial products
    // ==================================================================

    const int row = blockIdx.x;
    const half* w_row = proj_weight + row * HIDDEN;

    // Each thread accumulates partial dot product
    float dot_acc = 0.0f;

    // Vectorized path: process pairs via half2
    // HIDDEN_HALF2 is the number of half2 elements
    constexpr int HIDDEN_HALF2 = HIDDEN / 2;
    constexpr int PAIRS_PER_THREAD = (HIDDEN_HALF2 + NTHREADS - 1) / NTHREADS;

    const half2* w_row_h2 = reinterpret_cast<const half2*>(w_row);

    #pragma unroll
    for (int i = 0; i < PAIRS_PER_THREAD; i++) {
        int pair_idx = tid + i * NTHREADS;
        if (pair_idx < HIDDEN_HALF2) {
            half2 w2 = w_row_h2[pair_idx];
            float w_lo = __half2float(__low2half(w2));
            float w_hi = __half2float(__high2half(w2));
            dot_acc += normalized[pair_idx * 2]     * w_lo;
            dot_acc += normalized[pair_idx * 2 + 1] * w_hi;
        }
    }

    // Handle odd trailing element if HIDDEN is not even
    if ((HIDDEN & 1) && tid == 0) {
        dot_acc += normalized[HIDDEN - 1] * __half2float(w_row[HIDDEN - 1]);
    }

    // Warp shuffle reduction within each warp
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1) {
        dot_acc += __shfl_down_sync(0xffffffff, dot_acc, offset);
    }

    // First lane of each warp writes to shared memory
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;
    constexpr int NUM_WARPS = NTHREADS / 32;

    if (lane_id == 0) {
        reduce[warp_id] = dot_acc;
    }
    __syncthreads();

    // Final reduction across warps (first warp only)
    if (warp_id == 0) {
        float val = (lane_id < NUM_WARPS) ? reduce[lane_id] : 0.0f;
        #pragma unroll
        for (int offset = 16; offset > 0; offset >>= 1) {
            val += __shfl_down_sync(0xffffffff, val, offset);
        }

        // ==============================================================
        // Phase 3: Write output as f16
        // ==============================================================
        if (lane_id == 0) {
            output[row] = __float2half(val);
        }
    }
}
