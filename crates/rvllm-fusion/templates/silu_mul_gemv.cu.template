// Fused SiLU*Mul + GEMV kernel template.
// Generated by rvllm-fusion compiler -- do not edit by hand.
//
// Computes:
//   activation[i] = silu(gate[i]) * up[i]          for i in [0, INTERMEDIATE_SIZE)
//   output[j]     = dot(activation, down[j, :])     for j in [0, HIDDEN_SIZE)
//
// Compile-time constants let the compiler fully unroll inner loops,
// eliminate branches on dimension checks, and optimally allocate registers.

#include <cuda_fp16.h>

// Compile-time constants from fusion compiler
constexpr int INTERMEDIATE_SIZE = {{INTERMEDIATE_SIZE}};
constexpr int HIDDEN_SIZE       = {{HIDDEN_SIZE}};
constexpr int THREADS           = {{THREADS}};

// Number of half2 elements per vector (2 fp16 values packed)
constexpr int HALF2_STRIDE = INTERMEDIATE_SIZE / 2;

extern "C"
__global__ void {{KERNEL_NAME}}(
    const half* __restrict__ gate,          // [INTERMEDIATE_SIZE]
    const half* __restrict__ up,            // [INTERMEDIATE_SIZE]
    const half* __restrict__ down_weight,   // [HIDDEN_SIZE, INTERMEDIATE_SIZE] row-major
    half*       __restrict__ output         // [HIDDEN_SIZE]
) {
    // Each block computes one output element: output[blockIdx.x]
    const int row = blockIdx.x;

    // Pointer to this row of down_weight
    const half2* w_row = reinterpret_cast<const half2*>(down_weight + row * INTERMEDIATE_SIZE);
    const half2* gate2 = reinterpret_cast<const half2*>(gate);
    const half2* up2   = reinterpret_cast<const half2*>(up);

    // f32 partial sum -- accumulate in full precision to avoid catastrophic cancellation
    float partial = 0.0f;

    // Stride over the intermediate dimension in half2 (2 elements at a time).
    // Loop bounds are compile-time constants so the compiler can fully unroll.
    #pragma unroll 4
    for (int i = threadIdx.x; i < HALF2_STRIDE; i += THREADS) {
        // Vectorized loads: each loads 2 fp16 values
        half2 g = gate2[i];
        half2 u = up2[i];
        half2 w = w_row[i];

        // Unpack to f32 for silu computation
        float g0 = __half2float(g.x);
        float g1 = __half2float(g.y);
        float u0 = __half2float(u.x);
        float u1 = __half2float(u.y);
        float w0 = __half2float(w.x);
        float w1 = __half2float(w.y);

        // silu(x) = x / (1 + exp(-x))
        float s0 = g0 / (1.0f + expf(-g0));
        float s1 = g1 / (1.0f + expf(-g1));

        // activation = silu(gate) * up, then dot with weight
        partial += s0 * u0 * w0;
        partial += s1 * u1 * w1;
    }

    // Warp shuffle reduction -- reduce within each warp
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1) {
        partial += __shfl_xor_sync(0xffffffff, partial, offset);
    }

    // Cross-warp reduction via shared memory
    constexpr int NUM_WARPS = THREADS / 32;
    __shared__ float warp_sums[NUM_WARPS];

    const int lane   = threadIdx.x & 31;
    const int warpId = threadIdx.x >> 5;

    if (lane == 0) {
        warp_sums[warpId] = partial;
    }
    __syncthreads();

    // First warp reduces across all warp partial sums
    if (warpId == 0) {
        float val = (lane < NUM_WARPS) ? warp_sums[lane] : 0.0f;

        #pragma unroll
        for (int offset = 16; offset > 0; offset >>= 1) {
            val += __shfl_xor_sync(0xffffffff, val, offset);
        }

        // Lane 0 writes the final f16 result
        if (lane == 0) {
            output[row] = __float2half(val);
        }
    }
}
