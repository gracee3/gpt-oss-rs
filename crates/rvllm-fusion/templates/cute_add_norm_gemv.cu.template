// Fused ElemAdd + RMSNorm + GEMV using CuTE (CUTLASS 3.x)
//
// Three-way fusion -- highest impact. Replaces 3 kernel launches with 1.
//
// residual[i] = input[i] + add[i]
// normed[i]   = rmsnorm(residual, norm_weight, eps)[i]
// output[j]   = dot(normed, proj_weight[j, :])
//
// Also writes residual_out (needed for skip connection, written by block 0 only).
//
// Grid: ({{OUT_DIM}}, 1, 1)  Block: ({{THREADS}}, 1, 1)
// Shared: {{HIDDEN_SIZE}} * sizeof(float) + NUM_WARPS * sizeof(float)

#include <cute/tensor.hpp>
#include <cuda_fp16.h>

using namespace cute;

constexpr int HIDDEN = {{HIDDEN_SIZE}};
constexpr int OUTDIM = {{OUT_DIM}};
constexpr int NTHREADS = {{THREADS}};
constexpr int NWARPS = NTHREADS / 32;
constexpr float RMS_EPS = {{EPS}};

extern "C"
__global__ void __launch_bounds__(NTHREADS)
{{KERNEL_NAME}}(
    __half* __restrict__ output,         // [OUT_DIM] f16
    __half* __restrict__ residual_out,   // [HIDDEN]  f16 (skip connection)
    const __half* __restrict__ input,    // [HIDDEN]  f16
    const __half* __restrict__ add,      // [HIDDEN]  f16
    const __half* __restrict__ norm_weight, // [HIDDEN] f16
    const __half* __restrict__ proj_weight, // [OUT_DIM, HIDDEN] f16
    float eps,
    int hidden_size,
    int out_dim
) {
    const int row = blockIdx.x;
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    extern __shared__ float smem[];
    float* s_hidden = smem;
    float* s_warp = smem + HIDDEN;

    // CuTE tensor views
    auto g_input = make_tensor(make_gmem_ptr(input), make_layout(Int<HIDDEN>{}));
    auto g_add = make_tensor(make_gmem_ptr(add), make_layout(Int<HIDDEN>{}));
    auto g_norm = make_tensor(make_gmem_ptr(norm_weight), make_layout(Int<HIDDEN>{}));
    auto s_buf = make_tensor(make_smem_ptr(s_hidden), make_layout(Int<HIDDEN>{}));

    // -- Phase 1: Compute residual = input + add, store to shared memory --
    // Also compute sum-of-squares for RMSNorm and write residual_out (block 0 only)
    float thread_sq = 0.0f;
    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        float v = __half2float(g_input(i)) + __half2float(g_add(i));
        s_buf(i) = v;
        thread_sq += v * v;
        // Only block 0 writes the residual to global memory (all blocks compute
        // the same values, but writing from one block avoids redundant stores)
        if (row == 0) {
            residual_out[i] = __float2half(v);
        }
    }

    // Warp-level sum-of-squares reduction
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1)
        thread_sq += __shfl_xor_sync(0xffffffff, thread_sq, offset);

    if (lane_id == 0) s_warp[warp_id] = thread_sq;
    __syncthreads();

    float sum_sq;
    if (tid == 0) {
        sum_sq = 0.0f;
        for (int w = 0; w < NWARPS; w++) sum_sq += s_warp[w];
        s_warp[0] = sum_sq;
    }
    __syncthreads();
    sum_sq = s_warp[0];

    // -- Phase 2: Normalize in shared memory --
    float rms_scale = rsqrtf(sum_sq / float(HIDDEN) + RMS_EPS);

    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        s_buf(i) = s_buf(i) * rms_scale * __half2float(g_norm(i));
    }
    __syncthreads();

    // -- Phase 3: Dot product with proj_weight[row, :] --
    const __half* weight_row = proj_weight + row * HIDDEN;
    float dot = 0.0f;

    // Vectorized half2 loads for weight matrix
    constexpr int HIDDEN_H2 = HIDDEN / 2;
    const __half2* w_h2 = reinterpret_cast<const __half2*>(weight_row);

    for (int i = tid; i < HIDDEN_H2; i += NTHREADS) {
        __half2 w2 = w_h2[i];
        dot += s_buf(2 * i) * __half2float(w2.x) + s_buf(2 * i + 1) * __half2float(w2.y);
    }

    if (HIDDEN % 2 != 0 && tid == 0) {
        dot += s_buf(HIDDEN - 1) * __half2float(weight_row[HIDDEN - 1]);
    }

    // Warp reduction
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1)
        dot += __shfl_xor_sync(0xffffffff, dot, offset);

    if (lane_id == 0) s_warp[warp_id] = dot;
    __syncthreads();

    if (tid == 0) {
        float total = 0.0f;
        for (int w = 0; w < NWARPS; w++) total += s_warp[w];
        output[row] = __float2half(total);
    }
}
