// Fused ElementwiseAdd + RMSNorm + GEMV kernel (f16 I/O, f32 accumulation).
//
// This is the highest-impact 3-op fusion for LLM decode: it replaces three
// separate kernel launches (residual add, RMSNorm, linear projection) with a
// single kernel that keeps the hidden state in shared memory the entire time.
//
//   residual[i]  = input[i] + add[i]
//   normed[i]    = residual[i] * norm_weight[i] / rms(residual)
//   output[j]    = dot(normed[:], proj_weight[j, :])
//
// where rms(x) = sqrt(mean(x^2) + eps)
//
// The kernel also writes the residual to a separate output buffer for the
// skip-connection path used by later layers.
//
// Launch config:
//   Grid:  ({{OUT_DIM}}, 1, 1)    -- one block per output element
//   Block: ({{THREADS}}, 1, 1)
//   Shared memory: {{HIDDEN_SIZE}} * sizeof(float) + NUM_WARPS * sizeof(float)
//
// Template placeholders (filled at codegen time):
//   {{KERNEL_NAME}}  -- unique function name for this specialization
//   {{HIDDEN_SIZE}}  -- compile-time hidden dimension (e.g. 1536, 4096)
//   {{OUT_DIM}}      -- compile-time output dimension
//   {{THREADS}}      -- threads per block (256)
//   {{EPS}}          -- RMSNorm epsilon (e.g. 1e-6f)

#include <cuda_fp16.h>

// Compile-time constants baked from template parameters.
#define HIDDEN_SIZE {{HIDDEN_SIZE}}
#define OUT_DIM     {{OUT_DIM}}
#define THREADS     {{THREADS}}
#define EPS         {{EPS}}
#define NUM_WARPS   (THREADS / 32)

// Warp-level sum reduction via shuffle-down.
__device__ __forceinline__ float warp_reduce_sum(float val) {
    #pragma unroll
    for (int offset = 16; offset > 0; offset >>= 1) {
        val += __shfl_down_sync(0xffffffff, val, offset);
    }
    return val;
}

extern "C"
__global__ void __launch_bounds__(THREADS)
{{KERNEL_NAME}}(
    __half* __restrict__       output,       // [OUT_DIM]          -- projection result
    __half* __restrict__       residual_out, // [HIDDEN_SIZE]      -- skip-connection output
    const __half* __restrict__ input,        // [HIDDEN_SIZE]      -- current layer input
    const __half* __restrict__ add,          // [HIDDEN_SIZE]      -- residual to add
    const __half* __restrict__ norm_weight,  // [HIDDEN_SIZE]      -- RMSNorm gamma
    const __half* __restrict__ proj_weight   // [OUT_DIM, HIDDEN_SIZE] row-major
) {
    const int row = blockIdx.x;  // which output element this block computes
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    // Shared memory layout:
    //   [0 .. HIDDEN_SIZE-1]                 : residual / normalized hidden (f32)
    //   [HIDDEN_SIZE .. HIDDEN_SIZE+NUM_WARPS-1] : warp partial sums (reduction scratch)
    extern __shared__ float smem[];
    float* s_hidden = smem;
    float* s_warp   = smem + HIDDEN_SIZE;

    // =========================================================================
    // Phase 1: Elementwise add + store residual + compute sum-of-squares
    // =========================================================================
    // All blocks redundantly compute the same residual and RMSNorm. This avoids
    // an intermediate global buffer for the normed hidden state (the expensive
    // part). The residual itself IS needed downstream, so block 0 writes it out.

    float local_ss = 0.0f;

    for (int i = tid; i < HIDDEN_SIZE; i += THREADS) {
        float val = __half2float(input[i]) + __half2float(add[i]);
        s_hidden[i] = val;
        local_ss += val * val;
    }

    // Only block 0 writes the residual to global memory (all blocks compute
    // the same values, so having one block write avoids redundant global stores).
    if (row == 0) {
        for (int i = tid; i < HIDDEN_SIZE; i += THREADS) {
            residual_out[i] = __float2half(s_hidden[i]);
        }
    }

    // =========================================================================
    // Phase 1b: Cross-thread reduction of sum-of-squares for RMSNorm
    // =========================================================================
    // Warp-shuffle reduction, then cross-warp via shared memory.

    local_ss = warp_reduce_sum(local_ss);

    if (lane_id == 0) {
        s_warp[warp_id] = local_ss;
    }
    __syncthreads();

    // First warp finalizes the reduction and computes rms_scale = rsqrt(mean(x^2) + eps).
    if (warp_id == 0) {
        float val = (lane_id < NUM_WARPS) ? s_warp[lane_id] : 0.0f;
        val = warp_reduce_sum(val);
        if (lane_id == 0) {
            s_warp[0] = rsqrtf(val / (float)HIDDEN_SIZE + EPS);
        }
    }
    __syncthreads();

    float rms_scale = s_warp[0];

    // =========================================================================
    // Phase 2: RMSNorm -- normalize in shared memory
    // =========================================================================
    // s_hidden[i] = residual[i] * norm_weight[i] * rms_scale

    for (int i = tid; i < HIDDEN_SIZE; i += THREADS) {
        s_hidden[i] = s_hidden[i] * __half2float(norm_weight[i]) * rms_scale;
    }
    __syncthreads();

    // =========================================================================
    // Phase 3: GEMV dot product -- output[row] = dot(s_hidden, proj_weight[row,:])
    // =========================================================================
    const __half* w_row = proj_weight + (long long)row * HIDDEN_SIZE;

    float acc = 0.0f;

    // Vectorized half2 loads for weight (2 f16 values per 32-bit load).
    // Normed hidden is in shared memory as f32, indexed by scalar offset.
    const int h2 = HIDDEN_SIZE / 2;
    const half2* w2 = (const half2*)w_row;

    for (int i = tid; i < h2; i += THREADS) {
        half2 w = w2[i];
        int base = i * 2;
        acc += __half2float(w.x) * s_hidden[base];
        acc += __half2float(w.y) * s_hidden[base + 1];
    }

    // Handle odd HIDDEN_SIZE (unlikely for real models but correct).
    #if (HIDDEN_SIZE & 1)
    if (tid == 0) {
        acc += __half2float(w_row[HIDDEN_SIZE - 1]) * s_hidden[HIDDEN_SIZE - 1];
    }
    #endif

    // Warp-level reduction of dot product partial sums.
    acc = warp_reduce_sum(acc);

    if (lane_id == 0) {
        s_warp[warp_id] = acc;
    }
    __syncthreads();

    // Final reduction in first warp -> write output[row] as f16.
    if (warp_id == 0) {
        float val = (lane_id < NUM_WARPS) ? s_warp[lane_id] : 0.0f;
        val = warp_reduce_sum(val);
        if (lane_id == 0) {
            output[row] = __float2half(val);
        }
    }
}
